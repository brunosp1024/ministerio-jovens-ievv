{$DOMAIN} {
    # API
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Evolution API
    handle /evolution-api/* {
        reverse_proxy evolution-api:8080
    }

    # Health check
    handle /health {
        reverse_proxy backend:8000
    }

    # Frontend
    handle {
        reverse_proxy frontend:3000
    }
}
