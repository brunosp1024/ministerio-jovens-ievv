# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROCAR_SENHA_SEGURA
POSTGRES_DB=meu_banco_de_dados
DATABASE_URL=postgresql+asyncpg://postgres:TROCAR_SENHA_SEGURA@db:5432/meu_banco_de_dados
SQLALCHEMY_DATABASE_URI=postgresql://postgres:TROCAR_SENHA_SEGURA@db:5432/meu_banco_de_dados

# ---- Backend ----
SECRET_KEY=TROCAR_CHAVE_SEGURA_COM_32_CARACTERES_OU_MAIS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=TROCAR_SENHA_ADMIN
ACCESS_TOKEN_EXPIRE_HOURS=12
ENVIRONMENT=production
ALLOWED_ORIGINS=["https://seudominio.com.br"]
TZ=America/Sao_Paulo
UVICORN_WORKERS=2

# ---- Webhook (produção) ----
WEBHOOK_SECRET=TROCAR_CHAVE_WEBHOOK_SEGURA

# ---- Frontend ----
# URL pública da API (como vista pelo navegador do usuário)
NEXT_PUBLIC_API_URL=https://seudominio.com.br/api/v1

# ---- Domínio (Caddy gera HTTPS automático via Let's Encrypt) ----
DOMAIN=seudominio.com.br

# ---- WhatsApp / Evolution API (opcional) ----
WHATSAPP_ENABLED=false
WHATSAPP_RECIPIENT_PHONE=
WHATSAPP_TIMEOUT_SECONDS=30
EVOLUTION_API_URL=http://evolution-api:8080
AUTHENTICATION_API_KEY=SUA_CHAVE_DE_API_PARA_EVOLUTION_API
EVOLUTION_INSTANCE_NAME=ministerio-jovens-ievv
EVOLUTION_DOMAIN=evolution.seudominio.com.br

# Evolution API DB config
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://verbo_da_vida:TROCAR_SENHA_SEGURA@db:5432/evolution_api
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
SERVER_PORT=8080

# ---- Redis (necessário com perfil whatsapp) ----
REDIS_PASSWORD=TROCAR_SENHA_REDIS
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:TROCAR_SENHA_REDIS@redis:6379
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_LOCAL_ENABLED=false

# ---- Logs ----
LOG_LEVEL=WARN
LOG_BAILEYS=silent
