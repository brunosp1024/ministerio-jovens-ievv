# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=my_secret_password
POSTGRES_DB=my_database
DATABASE_URL=postgresql+asyncpg://postgres:my_secret_password@db:5432/my_database
SQLALCHEMY_DATABASE_URI=postgresql://postgres:my_secret_password@db:5432/my_database

# ---- Backend ----
SECRET_KEY="your-secret-key-here-change-in-production"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ACCESS_TOKEN_EXPIRE_HOURS=12
ENVIRONMENT="development"
ALLOWED_ORIGINS=["http://localhost:3000"]
TZ="America/Sao_Paulo"
UVICORN_WORKERS=2

# ---- Frontend ----
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"

# ---- Domínio (Caddy gera HTTPS automático via Let's Encrypt) ----
DOMAIN="localhost"

# ---- WhatsApp / Evolution API (opcional) ----
WHATSAPP_ENABLED=true
WHATSAPP_RECIPIENT_PHONE="5587YOUR_PHONE_NUMBER"
WHATSAPP_TIMEOUT_SECONDS=10
EVOLUTION_API_URL="http://evolution-api:8080"
EVOLUTION_API_KEY="your-evolution-api-key-here"
EVOLUTION_INSTANCE_NAME="ministerio-jovens-ievv"
AUTHENTICATION_API_KEY="your-authentication-api-key-here"

# ---- Evolution API DB config ----
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI="postgresql://postgres:my_secret_password@db:5432/evolution_api"
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
SERVER_PORT=8080

# ---- Redis (necessário com perfil whatsapp) ----
REDIS_PASSWORD=my_secret_password
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI="redis://:my_secret_password@redis:6379"
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_LOCAL_ENABLED=false

# ---- Logs ----
LOG_LEVEL=WARN
LOG_BAILEYS=silent
